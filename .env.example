# Apify LinkedIn Ads Scraper
APIFY_API_TOKEN=
APIFY_MONTHLY_SPEND_LIMIT=50

# Vercel Cron (set in Vercel dashboard; min 16 chars for /api/cron/sync-scrapes)
CRON_SECRET=

# ScrapeCreators (optional; set linkedinScraper to "scrapecreators" in Admin → Settings)
SCRAPECREATORS_API_KEY=

# Resend (approval/rejection emails). Get key at resend.com. For localhost, add to .env
RESEND_API_KEY=
# Optional: custom from address (default: onboarding@resend.dev). With free tier, only the Resend-verified email can receive.
# EMAIL_FROM=onboarding@resend.dev
# NEXT_PUBLIC_APP_URL=http://localhost:3000
